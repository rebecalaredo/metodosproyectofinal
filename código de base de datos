SET FOREIGN_KEY_CHECKS = 0;
 
CREATE TABLE `roles` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `nombre` VARCHAR(50) NOT NULL UNIQUE,
  `descripcion` VARCHAR(255)
);
 
CREATE TABLE `permisos` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `nombre` VARCHAR(100) NOT NULL UNIQUE,
  `descripcion` VARCHAR(255)
);
 
CREATE TABLE `rol_permisos` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `rol_id` INT NOT NULL,
  `permiso_id` INT NOT NULL,
  UNIQUE KEY `uk_rol_permiso` (`rol_id`, `permiso_id`)
);
 
CREATE TABLE `usuarios` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `nombre` VARCHAR(255) NOT NULL,
  `matricula` VARCHAR(50) UNIQUE,
  `correo` VARCHAR(255) UNIQUE,
  `password` VARCHAR(255) NOT NULL,
  `rol_id` INT NOT NULL,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'activo',
  `fecha_creacion` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);
 
CREATE TABLE `profesores` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL UNIQUE,
  `departamento` VARCHAR(255),
  `especialidad` VARCHAR(255),
  `estado` VARCHAR(20) NOT NULL DEFAULT 'activo'
);
 
CREATE TABLE `alumnos` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL UNIQUE,
  `carrera` VARCHAR(255),
  `semestre` INT,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'activo'
);
 
CREATE TABLE `libros` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `titulo` VARCHAR(255) NOT NULL,
  `editorial` VARCHAR(255),
  `isbn` VARCHAR(20) UNIQUE,
  `categoria` VARCHAR(100),
  `idioma` VARCHAR(50),
  `año_publicacion` INT,
  `paginas` INT,
  `ubicacion` VARCHAR(100),
  `precio_reposicion` DECIMAL(10,2),
  `descripcion` TEXT
);
 
CREATE TABLE `autores` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `nombre` VARCHAR(255) NOT NULL
);
 
CREATE TABLE `libro_autor` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `libro_id` INT NOT NULL,
  `autor_id` INT NOT NULL,
  UNIQUE KEY `uk_libro_autor` (`libro_id`, `autor_id`)
);
 
CREATE TABLE `copias_libros` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `libro_id` INT NOT NULL,
  `codigo_interno` VARCHAR(50) NOT NULL UNIQUE,
  `estado` VARCHAR(30) NOT NULL DEFAULT 'disponible'
);
 
CREATE TABLE `reservas` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL,
  `libro_id` INT NOT NULL,
  `copia_id` INT NULL,
  `fecha_inicio` DATE NOT NULL,
  `fecha_fin` DATE NOT NULL,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'pendiente',
  `fecha_creacion` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);
 
CREATE TABLE `prestamos` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL,
  `copia_id` INT NOT NULL,
  `reserva_id` INT NULL,
  `fecha_prestamo` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `fecha_vencimiento` DATETIME NOT NULL,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'activo'
);
 
CREATE TABLE `devoluciones` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `prestamo_id` INT NOT NULL UNIQUE,
  `fecha_devolucion` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `condicion_libro` VARCHAR(50) NOT NULL DEFAULT 'buena'
);
 
CREATE TABLE `tipos_multa` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `nombre` VARCHAR(100) NOT NULL UNIQUE,
  `monto_diario` DECIMAL(10,2),
  `descripcion` VARCHAR(255)
);
 
CREATE TABLE `multas` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL,
  `prestamo_id` INT NOT NULL,
  `tipo_id` INT NOT NULL,
  `monto` DECIMAL(10,2) NOT NULL,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'pendiente',
  `fecha_generacion` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);
 
CREATE TABLE `pagos` (
  `id` INT PRIMARY KEY AUTO_INCREMENT,
  `usuario_id` INT NOT NULL,
  `multa_id` INT NULL,
  `monto` DECIMAL(10,2) NOT NULL,
  `concepto` VARCHAR(255),
  `fecha_pago` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `estado` VARCHAR(20) NOT NULL DEFAULT 'completado'
);
 
ALTER TABLE `usuarios`
  ADD CONSTRAINT `fk_usuarios_rol` FOREIGN KEY (`rol_id`) REFERENCES `roles` (`id`);
 
ALTER TABLE `profesores`
  ADD CONSTRAINT `fk_profesores_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `alumnos`
  ADD CONSTRAINT `fk_alumnos_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `rol_permisos`
  ADD CONSTRAINT `fk_rolperm_rol` FOREIGN KEY (`rol_id`) REFERENCES `roles` (`id`) ON DELETE CASCADE,
  ADD CONSTRAINT `fk_rolperm_permiso` FOREIGN KEY (`permiso_id`) REFERENCES `permisos` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `libro_autor`
  ADD CONSTRAINT `fk_la_libro` FOREIGN KEY (`libro_id`) REFERENCES `libros` (`id`) ON DELETE CASCADE,
  ADD CONSTRAINT `fk_la_autor` FOREIGN KEY (`autor_id`) REFERENCES `autores` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `copias_libros`
  ADD CONSTRAINT `fk_copias_libro` FOREIGN KEY (`libro_id`) REFERENCES `libros` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `reservas`
  ADD CONSTRAINT `fk_reservas_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`),
  ADD CONSTRAINT `fk_reservas_libro` FOREIGN KEY (`libro_id`) REFERENCES `libros` (`id`),
  ADD CONSTRAINT `fk_reservas_copia` FOREIGN KEY (`copia_id`) REFERENCES `copias_libros` (`id`);
 
ALTER TABLE `prestamos`
  ADD CONSTRAINT `fk_prestamos_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`),
  ADD CONSTRAINT `fk_prestamos_copia` FOREIGN KEY (`copia_id`) REFERENCES `copias_libros` (`id`),
  ADD CONSTRAINT `fk_prestamos_reserva` FOREIGN KEY (`reserva_id`) REFERENCES `reservas` (`id`);
 
ALTER TABLE `devoluciones`
  ADD CONSTRAINT `fk_devoluciones_prestamo` FOREIGN KEY (`prestamo_id`) REFERENCES `prestamos` (`id`) ON DELETE CASCADE;
 
ALTER TABLE `multas`
  ADD CONSTRAINT `fk_multas_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`),
  ADD CONSTRAINT `fk_multas_prestamo` FOREIGN KEY (`prestamo_id`) REFERENCES `prestamos` (`id`),
  ADD CONSTRAINT `fk_multas_tipo` FOREIGN KEY (`tipo_id`) REFERENCES `tipos_multa` (`id`);
 
ALTER TABLE `pagos`
  ADD CONSTRAINT `fk_pagos_usuario` FOREIGN KEY (`usuario_id`) REFERENCES `usuarios` (`id`),
  ADD CONSTRAINT `fk_pagos_multa` FOREIGN KEY (`multa_id`) REFERENCES `multas` (`id`);
 
SET FOREIGN_KEY_CHECKS = 1;
 
